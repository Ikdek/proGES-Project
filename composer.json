{
    "name": "ikdek/mypronoteges",
    "description": "MyPronoteGes — suivi des notes, des cours et de la vie scolaire",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.58"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "qa": [
            "@cs",
            "@stan",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
