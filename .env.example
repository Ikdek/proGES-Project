# Variables d'environnement de connexion à la base de données.
# Copiez ce fichier en `.env` pour personnaliser (docker compose le lit automatiquement).
# Les valeurs par défaut correspondent à la config XAMPP d'origine.

# Hôte de la base.
#   - En local (XAMPP / PHP natif) : localhost
#   - Via docker compose : db (nom du service MySQL) — déjà forcé dans docker-compose.yml
DB_HOST=localhost

# Nom de la base de données.
DB_NAME=progesdb

# Utilisateur MySQL.
DB_USER=root

# Mot de passe MySQL (vide par défaut).
# NB : si vous le changez, ajustez aussi la config du conteneur `db` dans docker-compose.yml.
DB_PASSWORD=
